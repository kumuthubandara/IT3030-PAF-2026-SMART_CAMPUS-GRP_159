# Copy to .env — Vite reads VITE_* at dev/build time.
#
# Dev tip: leave VITE_API_BASE_URL unset so the app calls `/api/...` on the Vite dev server;
# `vite.config.js` proxies `/api` to Spring Boot (default http://localhost:8081).
# Set VITE_API_BASE_URL only when you need a different API origin (e.g. production deploy).
# VITE_API_BASE_URL=http://localhost:8081
#
# QR check-in / phone scanning: localhost URLs in a QR code usually do NOT open on a phone.
# Set this to your dev machine LAN URL so scans work (same Wi‑Fi as your PC), then restart Vite.
# Example: VITE_PUBLIC_APP_ORIGIN=http://192.168.1.10:5173
# Production: VITE_PUBLIC_APP_ORIGIN=https://your-campus-app.example.com
# VITE_PUBLIC_APP_ORIGIN=
