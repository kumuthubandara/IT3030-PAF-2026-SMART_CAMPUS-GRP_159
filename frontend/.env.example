# Copy to .env — Vite reads VITE_* at dev/build time.
#
# Dev server bind (optional): with `host: true`, Vite lists every network address (Hyper-V / virtual switches + real Wi‑Fi).
# Set this to your actual LAN IP (the one your phone should use) to get a single "Network" line in the terminal.
# VITE_DEV_BIND_HOST=192.168.8.116
#
# Dev tip: leave VITE_API_BASE_URL unset so the app calls `/api/...` on the Vite dev server;
# `vite.config.js` proxies `/api` to Spring Boot (default http://localhost:8081).
# Set VITE_API_BASE_URL only when you need a different API origin (e.g. production deploy).
# VITE_API_BASE_URL=http://localhost:8081
#
# Approved booking QR codes encode plain text (no URL / no localhost issue on phones).
# Optional: absolute origin for manual `/check-in/:id` links if you build those elsewhere.
# VITE_PUBLIC_APP_ORIGIN=
