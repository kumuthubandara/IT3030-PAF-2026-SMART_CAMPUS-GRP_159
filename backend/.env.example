# Copy to backend/.env (same folder as mvnw.cmd). Never commit .env.

# Required for MongoDB resources API
MONGODB_USERNAME=duminduakhila2003_db_user
MONGODB_PASSWORD=Smart_campus1234
MONGODB_URI=mongodb+srv://duminduakhila2003_db_user:Smart_campus1234@cluster0.1bxbmny.mongodb.net/smart_campus?retryWrites=true&w=majority

# Optional: use local MySQL instead of embedded H2 for JPA (contact + activity tables)
# SPRING_PROFILES_ACTIVE=mysql
# SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/smart_campus_db
# SPRING_DATASOURCE_USERNAME=your_mysql_user
# SPRING_DATASOURCE_PASSWORD=your_mysql_password

# Optional: Google OAuth2 login (Member 4)
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# FRONTEND_OAUTH_SUCCESS_URL=http://localhost:5173/login

# Optional: comma-separated emails that skip the "pending approval" step (e.g. first campus administrator).
# APP_AUTH_AUTO_APPROVE_EMAILS=you@campus.edu

# Optional: first administrator (only if MongoDB has no active ADMINISTRATOR yet). Remove password after first login.
# BOOTSTRAP_ADMIN_EMAIL=admin@mycampus.edu
# BOOTSTRAP_ADMIN_PASSWORD=choose-a-strong-password
