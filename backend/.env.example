# Copy to backend/.env (same folder as mvnw.cmd). Never commit .env.
#
# JAVA_HOME is NOT loaded from this file. Spring Boot / Maven use the JDK on your OS PATH or
# the JAVA_HOME environment variable (Windows: System Properties → Environment Variables).
# Use JDK 17 (matches pom.xml java.version). JAVA_HOME must point to the JDK root (folder that
# contains bin\java.exe), not the bin folder itself.

# MongoDB — required for /api/resources unless you rely on the local default in application.properties.
# Atlas: add your current public IP under Atlas → Network Access, or use 0.0.0.0/0 only for class demos.
#
# For local MongoDB only: delete MONGODB_URI from .env (or comment it out) so the app uses
# mongodb://127.0.0.1:27017/smart_campus and run mongod / Docker on port 27017.
#
MONGODB_USERNAME=duminduakhila2003_db_user
MONGODB_PASSWORD=Smart_campus1234
MONGODB_URI=mongodb+srv://duminduakhila2003_db_user:Smart_campus1234@cluster0.1bxbmny.mongodb.net/smart_campus?retryWrites=true&w=majority

# Optional: use local MySQL instead of embedded H2 for JPA (contact + activity tables)
# SPRING_PROFILES_ACTIVE=mysql
# SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/smart_campus_db
# SPRING_DATASOURCE_USERNAME=your_mysql_user
# SPRING_DATASOURCE_PASSWORD=your_mysql_password
