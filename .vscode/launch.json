{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "Backend (Spring Boot)",
      "request": "launch",
      "mainClass": "com.sliit.backend.BackendApplication",
      "projectName": "backend",
      "cwd": "${workspaceFolder}/backend"
    },
    {
      "type": "node",
      "name": "Frontend (Vite)",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}/frontend",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    }
  ],
  "compounds": [
    {
      "name": "Backend + Frontend",
      "configurations": ["Backend (Spring Boot)", "Frontend (Vite)"],
      "stopAll": true,
      "presentation": {
        "group": "fullstack",
        "order": 1
      }
    }
  ]
}
